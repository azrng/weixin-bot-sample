@page "/media"
@inherits DemoWorkspacePageBase

<PageTitle>微信 iLink Bot 演示 Demo - 媒体联调</PageTitle>

<DemoWorkspaceShell
    ShowFloatingNotice="@ShouldShowFloatingNotice()"
    FloatingNoticeError="@PageError"
    FloatingNoticeTitle="@GetFloatingNoticeTitle()"
    FloatingNoticeMessage="@GetFloatingNoticeMessage()"
    OnDismissNotice="DismissFloatingNotice"
    IsLoading="@IsLoading"
    Summary="媒体页专门处理上传、发送、下载回读和技术细节，方便对着真实账号做联调。"
    RuntimeStatusText="@GetRuntimeStatusText()"
    RuntimeStatusClass="@GetRuntimeStatusClass()"
    BindingStatusText="@GetBindingStatusText()"
    BindingStatusClass="@GetBindingStatusClass()"
    Eyebrow="媒体联调"
    Title="上传、发送与下载回读"
    Description="媒体消息演示单独成页，既方便观察长参数，也能避免整体页面被技术细节拖得太长。"
    Facts="@GetWorkspaceFacts()"
    NavigationItems="@DemoWorkspaceNavigation.Media">
    <MediaComposerSection
        MediaRequest="MediaRequest"
        IsSendingMedia="@IsSendingMedia"
        ShowSelfTargetHint="@ShouldShowMediaSelfTargetHint()"
        SelfTargetHint="@GetMediaSelfTargetHint()"
        ShowLatestFailureHint="@ShouldShowLatestMediaUploadFailureHint()"
        LatestFailureHint="@GetLatestMediaUploadFailureHint()"
        MediaValidationMessage="@MediaValidationMessage"
        MediaTargetHint="@GetMediaTargetHint()"
        IsVoiceMediaType="@IsVoiceMediaType()"
        MediaDescriptionLabel="@GetMediaDescriptionLabel()"
        SelectedMediaName="@(DisplayOrFallback(SelectedMediaName, "尚未选择文件"))"
        SelectedMediaSizeText="@(FormatFileSize(SelectedMediaSize))"
        SelectedMediaContentType="@(DisplayOrFallback(SelectedMediaContentType, "-"))"
        GetMediaFieldClass="GetMediaFieldClass"
        OnSend="SendMediaAsync"
        OnClearValidation="ClearMediaValidationMessage"
        OnFileChanged="OnMediaFileChanged" />

    <MediaRecordsSection
        Records="@(State?.MediaRecords ?? [])"
        IsSendingMedia="@IsSendingMedia"
        FormatDateTime="FormatDateTime"
        DisplayOrFallback="DisplayOrFallback"
        GetMediaStatusClass="GetMediaStatusClass"
        GetMediaStatusText="GetMediaStatusText"
        GetMediaTypeText="GetMediaTypeText"
        ShouldShowMediaTechnicalDetails="ShouldShowMediaTechnicalDetails"
        FormatFileSize="FormatFileSize"
        OnDownload="DownloadMediaAsync" />
</DemoWorkspaceShell>
