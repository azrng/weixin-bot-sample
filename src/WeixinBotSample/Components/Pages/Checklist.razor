@page "/checklist"
@inherits DemoWorkspacePageBase

<PageTitle>微信 iLink Bot 演示 Demo - 联调 Checklist</PageTitle>

<DemoWorkspaceShell
    ShowFloatingNotice="@ShouldShowFloatingNotice()"
    FloatingNoticeError="@PageError"
    FloatingNoticeTitle="@GetFloatingNoticeTitle()"
    FloatingNoticeMessage="@GetFloatingNoticeMessage()"
    OnDismissNotice="DismissFloatingNotice"
    IsLoading="@IsLoading"
    Summary="联调页聚焦真实账号验证，把连接自检、Checklist 和证据说明集中展示。"
    RuntimeStatusText="@GetRuntimeStatusText()"
    RuntimeStatusClass="@GetRuntimeStatusClass()"
    BindingStatusText="@GetBindingStatusText()"
    BindingStatusClass="@GetBindingStatusClass()"
    Eyebrow="真实联调"
    Title="Checklist 与验证证据"
    Description="这页不做花哨堆叠，重点是把已经验证的能力和还缺现场证据的环节分清楚。"
    Facts="@GetWorkspaceFacts()"
    NavigationItems="@DemoWorkspaceNavigation.Checklist">
    <ChecklistConnectionSection
        IsCheckingConnection="@IsCheckingConnection"
        LastCheckAt="@(FormatDateTime(State?.LastConnectionCheck?.CheckedAt))"
        LastCheckMessage="@(DisplayOrFallback(State?.LastConnectionCheck?.Message, "尚未执行连接自检"))"
        TypingTicket="@(DisplayOrFallback(State?.Configuration.TypingTicket, "未获取"))"
        TypingTicketUpdatedAt="@(FormatDateTime(State?.Configuration.TypingTicketUpdatedAt))"
        OnValidateConnection="ValidateConnectionAsync" />

    <ChecklistEnvironmentSection
        BindingStatusText="@GetBindingStatusText()"
        RuntimeStatusText="@GetRuntimeStatusText()"
        LatestContact="@(DisplayOrFallback(State?.KnownContacts.FirstOrDefault()?.ExternalChatId, "尚未接收到联系人上下文"))"
        LatestMediaRecord="@(DisplayOrFallback(State?.MediaRecords.FirstOrDefault()?.FileName, "尚无媒体联调记录"))" />

    <ChecklistItemsSection
        Items="@(State?.ChecklistItems ?? [])"
        IsRunningAllChecklist="@IsRunningAllChecklist"
        IsRunningChecklist="@IsRunningChecklist"
        ActiveChecklistCode="@ActiveChecklistCode"
        FormatDateTime="FormatDateTime"
        DisplayOrFallback="DisplayOrFallback"
        GetChecklistStatusClass="GetChecklistStatusClass"
        GetChecklistStatusText="GetChecklistStatusText"
        OnRunAll="RunAllChecklistAsync"
        OnRunItem="RunChecklistAsync" />
</DemoWorkspaceShell>
