@page "/messages"
@inherits DemoWorkspacePageBase

<PageTitle>微信 iLink Bot 演示 Demo - 消息中心</PageTitle>

<DemoWorkspaceShell
    ShowFloatingNotice="@ShouldShowFloatingNotice()"
    FloatingNoticeError="@PageError"
    FloatingNoticeTitle="@GetFloatingNoticeTitle()"
    FloatingNoticeMessage="@GetFloatingNoticeMessage()"
    OnDismissNotice="DismissFloatingNotice"
    IsLoading="@IsLoading"
    Summary="面向日常演示的消息工作区，集中处理联系人上下文、主动推送、消息记录和操作日志。"
    RuntimeStatusText="@GetRuntimeStatusText()"
    RuntimeStatusClass="@GetRuntimeStatusClass()"
    BindingStatusText="@GetBindingStatusText()"
    BindingStatusClass="@GetBindingStatusClass()"
    Eyebrow="消息中心"
    Title="上下文续聊与消息记录"
    Description="把日常收发消息相关操作放到一页里，避免和媒体、联调流程混在一起。"
    Facts="@GetWorkspaceFacts()"
    NavigationItems="@DemoWorkspaceNavigation.Messages">
    <MessagesKnownContactsSection
        Contacts="@(State?.KnownContacts ?? [])"
        FormatDateTime="FormatDateTime"
        DisplayOrFallback="DisplayOrFallback"
        OnUseKnownContact="UseKnownContact" />

    <MessagesPushSection
        PushRequest="PushRequest"
        IsPushing="@IsPushing"
        ShowAutoFillPrompt="@HasActiveAutoFillPrompt()"
        AutoFillPromptTitle="@GetAutoFillPromptTitle()"
        AutoFillPromptMessage="@GetAutoFillPromptMessage()"
        AutoFillExternalChatId="@ActiveAutoFillPrompt?.ExternalChatId"
        AutoFillContextToken="@ActiveAutoFillPrompt?.ContextToken"
        ShowReadinessNotice="@ShouldShowPushReadinessNotice()"
        ReadinessNotice="@GetPushReadinessNotice()"
        PushValidationMessage="@PushValidationMessage"
        PushTargetHint="@GetPushTargetHint()"
        LastPushResult="@State?.LastPushResult"
        GetPushFieldClass="GetPushFieldClass"
        FormatDateTime="FormatDateTime"
        OnSend="SendPushAsync"
        OnClearValidation="ClearPushValidationMessage" />

    <MessagesInboundSection
        Messages="@(State?.Messages ?? [])"
        FormatDateTime="FormatDateTime"
        DisplayOrFallback="DisplayOrFallback"
        GetReplyStatusClass="GetReplyStatusClass"
        GetReplyStatusSummary="GetReplyStatusSummary" />

    <MessagesLogsSection
        Logs="@(State?.Logs ?? [])"
        FormatDateTime="FormatDateTime" />
</DemoWorkspaceShell>
