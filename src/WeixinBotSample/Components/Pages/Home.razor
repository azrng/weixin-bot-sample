@page "/"

<PageTitle>微信 iLink Bot 演示 Demo</PageTitle>

@if (_isLoading)
{
    <section class="page-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="page-loading-text">正在加载微信演示状态...</p>
    </section>
}
else
{
    <main class="demo-shell">
        <section class="hero-panel">
            <div class="hero-panel__brand">
                <img src="images/app-icon.svg" alt="应用图标" class="hero-panel__icon" />
                <div>
                    <p class="hero-panel__eyebrow">Official WeChat iLink Bot Demo</p>
                    <h1>微信 iLink Bot 演示 Demo</h1>
                    <p class="hero-panel__summary">演示 Bot 绑定、用户发消息自动回复祝福语，以及主动推送消息。</p>
                </div>
            </div>
            <div class="hero-panel__status">
                <span class="status-chip @GetRuntimeStatusClass()">@GetRuntimeStatusText()</span>
                <span class="status-chip @GetBindingStatusClass()">@GetBindingStatusText()</span>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_pageError))
        {
            <div class="alert alert-danger demo-alert" role="alert">
                @_pageError
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_state?.LoadError))
        {
            <div class="alert alert-warning demo-alert" role="alert">
                @_state.LoadError
            </div>
        }

        <section class="demo-grid">
            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">基础配置</p>
                        <h2>连接参数</h2>
                    </div>
                    <button class="btn btn-primary" @onclick="SaveConfigurationAsync" disabled="@_isSaving">
                        @_saveButtonText
                    </button>
                </div>
                <div class="demo-form-grid">
                    <label class="demo-field">
                        <span>网关地址</span>
                        <input class="form-control" @bind="_configurationModel.BaseUrl" @bind:after="MarkConfigurationDirty" />
                    </label>
                    <label class="demo-field">
                        <span>RouteTag</span>
                        <input class="form-control" @bind="_configurationModel.RouteTag" @bind:after="MarkConfigurationDirty" />
                    </label>
                    <label class="demo-field">
                        <span>Token</span>
                        <input class="form-control" @bind="_configurationModel.Token" @bind:after="MarkConfigurationDirty" />
                    </label>
                    <label class="demo-field">
                        <span>账号 ID</span>
                        <input class="form-control" @bind="_configurationModel.AccountId" @bind:after="MarkConfigurationDirty" />
                    </label>
                    <label class="demo-field">
                        <span>用户 ID</span>
                        <input class="form-control" @bind="_configurationModel.UserId" @bind:after="MarkConfigurationDirty" />
                    </label>
                    <div class="demo-field demo-field--hint">
                        <span>协议版本</span>
                        <strong>@DisplayOrFallback(_state?.Configuration.ChannelVersion, "1.0.3")</strong>
                        <small>当前 Demo 按 iLink Bot 标准链路固定使用 `base_info.channel_version`。</small>
                    </div>
                    <div class="demo-field demo-field--hint">
                        <span>最近更新</span>
                        <strong>@FormatDateTime(_state?.Configuration.UpdatedAt)</strong>
                        <small>绑定成功后，Token / 账号 / 用户信息会自动回写到这里。</small>
                    </div>
                    <div class="demo-field demo-field--hint">
                        <span>轮询游标</span>
                        <strong class="technical-value" title="@DisplayOrFallback(_state?.Configuration.SyncCursor, "尚未建立")">
                            @DisplayOrFallback(_state?.Configuration.SyncCursor, "尚未建立")
                        </strong>
                        <small>`get_updates_buf` 会持久化保存，应用重启后可继续从上次位置接收消息。</small>
                    </div>
                </div>
            </article>

            <article class="demo-card">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">微信绑定</p>
                        <h2>二维码接入</h2>
                    </div>
                    <div class="demo-action-group">
                        <button class="btn btn-outline-primary" @onclick="BindWeChatAsync" disabled="@_isBinding">绑定微信</button>
                        <button class="btn btn-outline-secondary" @onclick="RefreshQrCodeAsync" disabled="@_isBinding">刷新二维码</button>
                    </div>
                </div>
                <div class="binding-panel">
                    @if (!string.IsNullOrWhiteSpace(_state?.ActiveBindingSession?.QrCodeDataUrl))
                    {
                        <img src="@_state.ActiveBindingSession.QrCodeDataUrl" alt="微信绑定二维码" class="binding-panel__qr" />
                    }
                    else
                    {
                        <div class="empty-block">
                            <div class="empty-block__icon">QR</div>
                            <p>点击“绑定微信”后，这里会显示扫码二维码。</p>
                        </div>
                    }

                    <dl class="meta-list">
                        <div>
                            <dt>绑定状态</dt>
                            <dd>@GetBindingStatusText()</dd>
                        </div>
                        <div>
                            <dt>绑定账号</dt>
                            <dd>@DisplayOrFallback(_state?.Configuration.BoundAccountName, "尚未绑定")</dd>
                        </div>
                        <div>
                            <dt>二维码状态</dt>
                            <dd>@DisplayOrFallback(_state?.ActiveBindingSession?.Message, "暂无进行中的绑定流程")</dd>
                        </div>
                        <div>
                            <dt>会话 Key</dt>
                            <dd>@DisplayOrFallback(_state?.ActiveBindingSession?.SessionKey, "-")</dd>
                        </div>
                    </dl>
                </div>
            </article>

            <article class="demo-card">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">监听控制</p>
                        <h2>消息接收</h2>
                    </div>
                    <div class="demo-action-group">
                        <button class="btn btn-success" @onclick="StartListeningAsync" disabled="@_isRuntimeWorking">启动监听</button>
                        <button class="btn btn-outline-danger" @onclick="StopListeningAsync" disabled="@_isRuntimeWorking">停止监听</button>
                    </div>
                </div>
                <dl class="meta-list">
                    <div>
                        <dt>当前状态</dt>
                        <dd>@GetRuntimeStatusText()</dd>
                    </div>
                    <div>
                        <dt>最近启动</dt>
                        <dd>@FormatDateTime(_state?.Configuration.RuntimeStartedAt)</dd>
                    </div>
                    <div>
                        <dt>最近停止</dt>
                        <dd>@FormatDateTime(_state?.Configuration.RuntimeStoppedAt)</dd>
                    </div>
                    <div>
                        <dt>错误信息</dt>
                        <dd>@DisplayOrFallback(_state?.Configuration.RuntimeError, "无")</dd>
                    </div>
                </dl>
            </article>

            <article class="demo-card">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">协议自检</p>
                        <h2>连接与 Typing 状态</h2>
                    </div>
                    <button class="btn btn-outline-primary" @onclick="ValidateConnectionAsync" disabled="@_isCheckingConnection">
                        @(_isCheckingConnection ? "检测中..." : "验证连接")
                    </button>
                </div>
                <dl class="meta-list">
                    <div>
                        <dt>最近自检</dt>
                        <dd>@FormatDateTime(_state?.LastConnectionCheck?.CheckedAt)</dd>
                    </div>
                    <div>
                        <dt>自检结果</dt>
                        <dd>@DisplayOrFallback(_state?.LastConnectionCheck?.Message, "尚未执行连接自检")</dd>
                    </div>
                    <div>
                        <dt>Typing Ticket</dt>
                        <dd class="technical-value" title="@DisplayOrFallback(_state?.Configuration.TypingTicket, "未获取")">
                            @DisplayOrFallback(_state?.Configuration.TypingTicket, "未获取")
                        </dd>
                    </div>
                    <div>
                        <dt>Ticket 更新时间</dt>
                        <dd>@FormatDateTime(_state?.Configuration.TypingTicketUpdatedAt)</dd>
                    </div>
                </dl>
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">协议说明</p>
                        <h2>能力总览与限制提示</h2>
                    </div>
                </div>
                <div class="explanation-panel">
                    <p>这个区块用来辅助演示，不只是告诉观众“能做什么”，还会解释“为什么这样做”。例如 `getconfig` 先拿 `typing_ticket`，是为了在真正发消息前触发“正在输入”状态；媒体消息要先加密再上 CDN，则是因为协议把文件链路单独放在 `c2c` 域名下处理。</p>
                    <p>当前 Demo 优先覆盖公开协议端点。对历史消息回溯、群聊能力边界、速率限制等官方未明确部分，这里会持续显示说明，而不是假装已经完全支持。</p>
                </div>
                <div class="table-responsive">
                    <table class="table demo-table">
                        <thead>
                            <tr>
                                <th>场景</th>
                                <th>当前状态</th>
                                <th>页面入口</th>
                                <th>说明</th>
                            </tr>
                        </thead>
                        <tbody>
                                @foreach (var capability in GetProtocolCapabilities())
                            {
                                <tr>
                                    <td>@capability.Scene</td>
                                    <td>@capability.Status</td>
                                    <td>@capability.Entry</td>
                                    <td class="technical-cell">@capability.Summary</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">上下文缓存</p>
                        <h2>已知联系人</h2>
                    </div>
                </div>
                @if (_state?.KnownContacts.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table demo-table">
                            <thead>
                                <tr>
                                    <th>最近会话</th>
                                    <th>联系人</th>
                                    <th>ExternalChatId</th>
                                    <th>ContextToken</th>
                                    <th>最近消息</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contact in _state.KnownContacts)
                                {
                                    <tr>
                                        <td>@FormatDateTime(contact.LastMessageAt)</td>
                                        <td>@DisplayOrFallback(contact.SenderName, contact.ExternalUserId)</td>
                                        <td class="technical-cell">@contact.ExternalChatId</td>
                                        <td class="technical-cell">@contact.LatestContextToken</td>
                                        <td class="technical-cell">@DisplayOrFallback(contact.LastMessageText, "-")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="@(() => UseKnownContact(contact))">带入推送</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-block empty-block--compact">
                        <div class="empty-block__icon">CTX</div>
                        <p>收到用户消息后，这里会缓存最近联系人和 `context_token`，方便主动推送继续对话。</p>
                    </div>
                }
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">媒体消息演示</p>
                        <h2>上传、发送与下载回读</h2>
                    </div>
                    <button class="btn btn-primary" @onclick="SendMediaAsync" disabled="@_isSendingMedia">
                        @(_isSendingMedia ? "处理中..." : "发送媒体消息")
                    </button>
                </div>
                <div class="explanation-panel">
                    <p>媒体链路和文本不同。这里会按协议做四步：计算摘要、获取 `upload_param`、AES 加密上传到 CDN、再调用 `sendmessage` 发送媒体结构。这样后面收到消息时，才能反向下载并用 `aes_key` 解密回读。</p>
                    <p>考虑到媒体参数通常很长，这个区域和下面的记录表都会对长内容做自动换行，避免把页面撑坏。</p>
                </div>
                <div class="demo-form-grid">
                    <label class="demo-field">
                        <span>ExternalChatId</span>
                        <input class="form-control" @bind="_mediaRequest.ExternalChatId" />
                    </label>
                    <label class="demo-field">
                        <span>ContextToken</span>
                        <input class="form-control" @bind="_mediaRequest.ContextToken" />
                    </label>
                    <label class="demo-field">
                        <span>媒体类型</span>
                        <select class="form-select" @bind="_mediaRequest.MediaType">
                            <option value="@MediaMessageType.Image">图片</option>
                            <option value="@MediaMessageType.Voice">语音</option>
                            <option value="@MediaMessageType.File">文件</option>
                            <option value="@MediaMessageType.Video">视频</option>
                        </select>
                    </label>
                    <label class="demo-field">
                        <span>语音编码类型</span>
                        <input class="form-control" type="number" min="1" @bind="_mediaRequest.EncodeType" />
                    </label>
                    <label class="demo-field demo-field--full">
                        <span>选择文件</span>
                        <InputFile OnChange="OnMediaFileChanged" class="form-control" />
                    </label>
                    <label class="demo-field demo-field--full">
                        <span>附加说明 / 语音 ASR 备注</span>
                        <textarea class="form-control demo-textarea" @bind="_mediaRequest.Description"></textarea>
                    </label>
                    <div class="demo-field demo-field--full demo-field--hint">
                        <span>当前文件</span>
                        <strong class="technical-value">@DisplayOrFallback(_selectedMediaName, "尚未选择文件")</strong>
                        <small>大小：@FormatFileSize(_selectedMediaSize)；类型：@DisplayOrFallback(_selectedMediaContentType, "-")</small>
                    </div>
                </div>
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">媒体记录</p>
                        <h2>最近媒体消息与缓存状态</h2>
                    </div>
                </div>
                @if (_state?.MediaRecords.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table demo-table">
                            <thead>
                                <tr>
                                    <th>时间</th>
                                    <th>方向</th>
                                    <th>类型</th>
                                    <th>文件</th>
                                    <th>状态</th>
                                    <th>摘要</th>
                                    <th>操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _state.MediaRecords)
                                {
                                    <tr>
                                        <td>@FormatDateTime(item.UpdatedAt)</td>
                                        <td>@item.Direction</td>
                                        <td>@GetMediaTypeText(item.MediaType)</td>
                                        <td class="technical-cell">@DisplayOrFallback(item.FileName, "未命名媒体")</td>
                                        <td>@GetMediaStatusText(item.TransferStatus)</td>
                                        <td class="technical-cell">@DisplayOrFallback(item.StatusMessage, item.ResponseSummary)</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="@(() => DownloadMediaAsync(item.Id))" disabled="@_isSendingMedia || string.IsNullOrWhiteSpace(item.DownloadParam) || string.IsNullOrWhiteSpace(item.AesKey)">下载并解密</button>
                                        </td>
                                    </tr>
                                    @if (ShouldShowMediaTechnicalDetails(item))
                                    {
                                        <tr class="demo-table__detail-row">
                                            <td colspan="7">
                                                <div class="technical-detail-grid">
                                                    @if (!string.IsNullOrWhiteSpace(item.AsrText))
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">语音 ASR</span>
                                                            <span class="technical-value">@item.AsrText</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.ContextToken))
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">ContextToken</span>
                                                            <span class="technical-value">@item.ContextToken</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.FileKey))
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">FileKey</span>
                                                            <span class="technical-value">@item.FileKey</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.Md5))
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">MD5</span>
                                                            <span class="technical-value">@item.Md5</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.AesKey))
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">AES Key</span>
                                                            <span class="technical-value">@item.AesKey</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.DownloadParam))
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">Download Param</span>
                                                            <span class="technical-value">@item.DownloadParam</span>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.LocalCachePath))
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">缓存路径</span>
                                                            <span class="technical-value">@item.LocalCachePath</span>
                                                        </div>
                                                    }
                                                    @if (item.FileSize > 0)
                                                    {
                                                        <div class="technical-detail">
                                                            <span class="technical-detail__label">文件大小</span>
                                                            <span class="technical-value">@FormatFileSize(item.FileSize)</span>
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-block empty-block--compact">
                        <div class="empty-block__icon">MED</div>
                        <p>媒体消息发出或收到后，这里会显示上传、发送、下载和解密的全过程状态。</p>
                    </div>
                }
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">联调检查</p>
                        <h2>真实账号 Checklist</h2>
                    </div>
                    <button class="btn btn-outline-primary" @onclick="RunAllChecklistAsync" disabled="@_isRunningAllChecklist">
                        @(_isRunningAllChecklist ? "检查中..." : "执行全部检查")
                    </button>
                </div>
                <div class="explanation-panel">
                    <p>这组检查项是为真实联调准备的。它不会假装替你完成真实验证，而是把“当前已经有证据的能力”和“还需要真实触发的场景”明确区分出来，避免演示时讲过头。</p>
                </div>
                @if (_state?.ChecklistItems.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table demo-table">
                            <thead>
                                <tr>
                                    <th>检查项</th>
                                    <th>状态</th>
                                    <th>最近执行</th>
                                    <th>说明</th>
                                    <th>证据</th>
                                    <th>操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _state.ChecklistItems)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@GetChecklistStatusText(item.Status)</td>
                                        <td>@FormatDateTime(item.CheckedAt)</td>
                                        <td class="technical-cell">@item.Message</td>
                                        <td class="technical-cell">@DisplayOrFallback(item.Evidence, item.Description)</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="@(() => RunChecklistAsync(item.Code))" disabled="@(_isRunningChecklist && _activeChecklistCode == item.Code)">
                                                @(_isRunningChecklist && _activeChecklistCode == item.Code ? "执行中..." : "执行")
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">主动推送示例</p>
                        <h2>向用户发送消息</h2>
                    </div>
                    <button class="btn btn-primary" @onclick="SendPushAsync" disabled="@_isPushing">推送演示消息</button>
                </div>
                <div class="demo-form-grid">
                    <label class="demo-field">
                        <span>ExternalChatId</span>
                        <input class="form-control" @bind="_pushRequest.ExternalChatId" />
                    </label>
                    <label class="demo-field">
                        <span>ContextToken</span>
                        <input class="form-control" @bind="_pushRequest.ContextToken" />
                    </label>
                    <label class="demo-field demo-field--full">
                        <span>推送内容</span>
                        <textarea class="form-control demo-textarea" @bind="_pushRequest.Content"></textarea>
                    </label>
                    <div class="demo-field demo-field--full demo-field--hint">
                        <span>默认目标</span>
                        <small>@GetPushTargetHint()</small>
                    </div>
                </div>

                @if (_state?.LastPushResult is not null)
                {
                    <div class="result-panel @( _state.LastPushResult.Succeeded ? "result-panel--success" : "result-panel--error")">
                        <p>@_state.LastPushResult.Message</p>
                        <small>发送时间：@FormatDateTime(_state.LastPushResult.SentAt)</small>
                        <small class="technical-value">响应摘要：@_state.LastPushResult.ResponseSummary</small>
                    </div>
                }

                @if (_state?.LastConnectionCheck is not null && !string.IsNullOrWhiteSpace(_state.LastConnectionCheck.ResponseSummary))
                {
                    <div class="result-panel @( _state.LastConnectionCheck.Succeeded ? "result-panel--success" : "result-panel--error")">
                        <p>@_state.LastConnectionCheck.Message</p>
                        <small>最近自检时间：@FormatDateTime(_state.LastConnectionCheck.CheckedAt)</small>
                        <small class="technical-value">响应摘要：@_state.LastConnectionCheck.ResponseSummary</small>
                    </div>
                }
            </article>

            <article class="demo-card">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">自动回复</p>
                        <h2>固定祝福语</h2>
                    </div>
                </div>
                <div class="greeting-panel">
                    <p class="greeting-panel__primary">@DisplayOrFallback(_state?.PrimaryGreeting, "-")</p>
                    <p class="greeting-panel__secondary">最近一次回复：@DisplayOrFallback(_state?.LatestReplyText, "还没有回复记录")</p>
                </div>
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">最近入站消息</p>
                        <h2>微信用户消息记录</h2>
                    </div>
                </div>
                @if (_state?.Messages.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table demo-table">
                            <thead>
                                <tr>
                                    <th>时间</th>
                                    <th>发送者</th>
                                    <th>会话 ID</th>
                                    <th>原文</th>
                                    <th>回复结果</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _state.Messages)
                                {
                                    <tr>
                                        <td>@FormatDateTime(item.CreatedAt)</td>
                                        <td>@DisplayOrFallback(item.SenderName, item.ExternalUserId)</td>
                                        <td class="technical-cell">@item.ExternalChatId</td>
                                        <td class="technical-cell">@item.Text</td>
                                        <td class="technical-cell">@item.ReplyStatus</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-block empty-block--compact">
                        <div class="empty-block__icon">MSG</div>
                        <p>监听启动后，收到的微信消息会显示在这里。</p>
                    </div>
                }
            </article>

            <article class="demo-card demo-card--wide">
                <div class="demo-card__header">
                    <div>
                        <p class="demo-card__eyebrow">操作日志</p>
                        <h2>关键链路可视化</h2>
                    </div>
                </div>
                @if (_state?.Logs.Count > 0)
                {
                    <ul class="log-list">
                        @foreach (var item in _state.Logs)
                        {
                            <li class="log-list__item">
                                <span class="log-list__time">@FormatDateTime(item.CreatedAt)</span>
                                <span class="log-list__badge log-list__badge--@item.Level.ToLowerInvariant()">@item.Level</span>
                                <span class="log-list__message">@item.Message</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="empty-block empty-block--compact">
                        <div class="empty-block__icon">LOG</div>
                        <p>操作日志会在这里实时沉淀，方便演示和排查。</p>
                    </div>
                }
            </article>
        </section>
    </main>
}
