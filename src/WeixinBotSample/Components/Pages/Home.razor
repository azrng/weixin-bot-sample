@page "/"
@inherits DemoWorkspacePageBase

<PageTitle>微信 iLink Bot 演示 Demo - 总览</PageTitle>

<DemoWorkspaceShell
    ShowFloatingNotice="@ShouldShowFloatingNotice()"
    FloatingNoticeError="@PageError"
    FloatingNoticeTitle="@GetFloatingNoticeTitle()"
    FloatingNoticeMessage="@GetFloatingNoticeMessage()"
    OnDismissNotice="DismissFloatingNotice"
    IsLoading="@IsLoading"
    Summary="演示 Bot 绑定、长轮询、主动推送与协议总览，首页聚焦系统状态和基础配置。"
    RuntimeStatusText="@GetRuntimeStatusText()"
    RuntimeStatusClass="@GetRuntimeStatusClass()"
    BindingStatusText="@GetBindingStatusText()"
    BindingStatusClass="@GetBindingStatusClass()"
    Eyebrow="总览首页"
    Title="连接状态与协议能力"
    Description="这一页保留最常用的绑定、监听、配置和能力矩阵，联调细节则拆到独立页面。"
    Facts="@GetWorkspaceFacts()"
    NavigationItems="@DemoWorkspaceNavigation.Home">
    @{
        var lastConnectionCheck = State?.LastConnectionCheck;
    }

    <HomeOverviewSection
        Insights="@GetOverviewInsights()"
        Recommendation="@GetOverviewRecommendation()" />

    <HomeConfigurationSection
        ConfigurationModel="ConfigurationModel"
        IsSaving="@IsSaving"
        SaveButtonText="@SaveButtonText"
        ChannelVersion="@(DisplayOrFallback(State?.Configuration.ChannelVersion, "1.0.3"))"
        UpdatedAt="@(FormatDateTime(State?.Configuration.UpdatedAt))"
        SyncCursor="@(DisplayOrFallback(State?.Configuration.SyncCursor, "尚未建立"))"
        OnMarkDirty="MarkConfigurationDirty"
        OnSave="SaveConfigurationAsync" />

    <HomeBindingSection
        IsBinding="@IsBinding"
        BindingStatusText="@GetBindingStatusText()"
        QrCodeDataUrl="@State?.ActiveBindingSession?.QrCodeDataUrl"
        BoundAccountName="@(DisplayOrFallback(State?.Configuration.BoundAccountName, "尚未绑定"))"
        QrCodeStatusMessage="@(DisplayOrFallback(State?.ActiveBindingSession?.Message, "暂无进行中的绑定流程"))"
        SessionKey="@(DisplayOrFallback(State?.ActiveBindingSession?.SessionKey, "-"))"
        OnBind="BindWeChatAsync"
        OnRefreshQrCode="RefreshQrCodeAsync" />

    <HomeRuntimeSection
        IsRuntimeWorking="@IsRuntimeWorking"
        RuntimeStatusText="@GetRuntimeStatusText()"
        RuntimeStartedAt="@(FormatDateTime(State?.Configuration.RuntimeStartedAt))"
        RuntimeStoppedAt="@(FormatDateTime(State?.Configuration.RuntimeStoppedAt))"
        RuntimeError="@(DisplayOrFallback(State?.Configuration.RuntimeError, "无"))"
        OnStartListening="StartListeningAsync"
        OnStopListening="StopListeningAsync" />

    <HomeConnectionSection
        IsCheckingConnection="@IsCheckingConnection"
        LastCheckAt="@(FormatDateTime(lastConnectionCheck?.CheckedAt))"
        LastCheckMessage="@(DisplayOrFallback(lastConnectionCheck?.Message, "尚未执行连接自检"))"
        TypingTicket="@(DisplayOrFallback(State?.Configuration.TypingTicket, "未获取"))"
        TypingTicketUpdatedAt="@(FormatDateTime(State?.Configuration.TypingTicketUpdatedAt))"
        PrimaryGreeting="@(DisplayOrFallback(State?.PrimaryGreeting, "-"))"
        LatestReplyText="@(DisplayOrFallback(State?.LatestReplyText, "还没有回复记录"))"
        ShowLatestResponse="@(lastConnectionCheck is not null && !string.IsNullOrWhiteSpace(lastConnectionCheck.ResponseSummary))"
        IsLatestResponseSuccess="@(lastConnectionCheck?.Succeeded == true)"
        LatestResponseMessage="@lastConnectionCheck?.Message"
        LatestResponseCheckedAt="@(FormatDateTime(lastConnectionCheck?.CheckedAt))"
        LatestResponseSummary="@lastConnectionCheck?.ResponseSummary"
        OnValidateConnection="ValidateConnectionAsync" />

    <HomeProtocolSection
        Capabilities="@GetProtocolCapabilities()"
        GetCapabilityStatusClass="GetCapabilityStatusClass" />
</DemoWorkspaceShell>
