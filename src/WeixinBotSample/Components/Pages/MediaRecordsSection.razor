@namespace WeixinBotSample.Components.Pages

<article class="demo-card demo-card--wide">
    <div class="demo-card__header">
        <div>
            <p class="demo-card__eyebrow">媒体记录</p>
            <h2>最近媒体消息与缓存状态</h2>
        </div>
    </div>
    @if (Records.Count > 0)
    {
        <div class="table-responsive">
            <table class="table demo-table">
                <thead>
                    <tr>
                        <th>时间</th>
                        <th>方向</th>
                        <th>类型</th>
                        <th>文件</th>
                        <th>状态</th>
                        <th>摘要</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Records)
                    {
                        <MediaRecordRow
                            Record="item"
                            ShowTechnicalDetails="@ShouldShowMediaTechnicalDetails(item)"
                            IsSendingMedia="@IsSendingMedia"
                            FormatDateTime="FormatDateTime"
                            DisplayOrFallback="DisplayOrFallback"
                            GetMediaStatusClass="GetMediaStatusClass"
                            GetMediaStatusText="GetMediaStatusText"
                            GetMediaTypeText="GetMediaTypeText"
                            FormatFileSize="FormatFileSize"
                            OnDownload="OnDownload" />
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-block empty-block--compact">
            <div class="empty-block__icon">MED</div>
            <p>媒体消息发出或收到后，这里会显示上传、发送、下载和解密的全过程状态。</p>
        </div>
    }
</article>

@code {
    [Parameter]
    public IReadOnlyList<MediaTransferRecord> Records { get; set; } = [];

    [Parameter]
    public bool IsSendingMedia { get; set; }

    [Parameter]
    public Func<DateTimeOffset?, string> FormatDateTime { get; set; } = _ => "-";

    [Parameter]
    public Func<string?, string, string> DisplayOrFallback { get; set; } = (_, fallback) => fallback;

    [Parameter]
    public Func<MediaTransferStatus, string> GetMediaStatusClass { get; set; } = _ => string.Empty;

    [Parameter]
    public Func<MediaTransferStatus, string> GetMediaStatusText { get; set; } = _ => string.Empty;

    [Parameter]
    public Func<MediaMessageType, string> GetMediaTypeText { get; set; } = _ => string.Empty;

    [Parameter]
    public Func<MediaTransferRecord, bool> ShouldShowMediaTechnicalDetails { get; set; } = _ => false;

    [Parameter]
    public Func<long, string> FormatFileSize { get; set; } = _ => "-";

    [Parameter]
    public EventCallback<string> OnDownload { get; set; }
}
