@using Microsoft.AspNetCore.Components.Routing

@if (ShowFloatingNotice)
{
    <div class="floating-notice @(string.IsNullOrWhiteSpace(FloatingNoticeError) ? "floating-notice--warning" : "floating-notice--error")" role="alert" aria-live="assertive">
        <div class="floating-notice__icon">!</div>
        <div class="floating-notice__content">
            <strong>@FloatingNoticeTitle</strong>
            <p class="technical-cell">@FloatingNoticeMessage</p>
        </div>
        <button type="button" class="floating-notice__close" @onclick="OnDismissNotice" aria-label="关闭提示">×</button>
    </div>
}

@if (IsLoading)
{
    <section class="page-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="page-loading-text">正在加载微信演示状态...</p>
    </section>
}
else
{
    <main class="demo-shell">
        <section class="hero-panel">
            <div class="hero-panel__brand">
                <img src="images/app-icon.svg" alt="应用图标" class="hero-panel__icon" />
                <div>
                    <p class="hero-panel__eyebrow">Official WeChat iLink Bot Demo</p>
                    <h1>微信 iLink Bot 演示 Demo</h1>
                    <p class="hero-panel__summary">@Summary</p>
                </div>
            </div>
            <div class="hero-panel__status">
                <span class="status-chip @RuntimeStatusClass">@RuntimeStatusText</span>
                <span class="status-chip @BindingStatusClass">@BindingStatusText</span>
            </div>
        </section>

        <section class="workspace-shell">
            <aside class="workspace-sidebar">
                <div class="workspace-sidebar__header">
                    <p class="demo-card__eyebrow">演示工作台</p>
                    <h2>功能导航</h2>
                    <p>把总览、消息、媒体、联调拆开，避免一页过长。</p>
                </div>

                <nav class="workspace-nav" aria-label="演示导航">
                    @foreach (var item in NavigationItems)
                    {
                        <NavLink class="workspace-nav__link" href="@item.Href" Match="@item.Match">
                            <span class="workspace-nav__icon">@item.Icon</span>
                            <span class="workspace-nav__text">
                                <strong>@item.Title</strong>
                                <small>@item.Description</small>
                            </span>
                        </NavLink>
                    }
                </nav>
            </aside>

            <section class="workspace-main">
                <header class="workspace-page-header">
                    <div>
                        <p class="demo-card__eyebrow">@Eyebrow</p>
                        <h2>@Title</h2>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Description))
                    {
                        <p>@Description</p>
                    }
                </header>

                <div class="demo-grid demo-grid--workspace">
                    @ChildContent
                </div>
            </section>
        </section>
    </main>
}

@code {
    [Parameter]
    public bool ShowFloatingNotice { get; set; }

    [Parameter]
    public string FloatingNoticeError { get; set; } = string.Empty;

    [Parameter]
    public string FloatingNoticeTitle { get; set; } = string.Empty;

    [Parameter]
    public string FloatingNoticeMessage { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnDismissNotice { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public string Summary { get; set; } = string.Empty;

    [Parameter]
    public string RuntimeStatusText { get; set; } = string.Empty;

    [Parameter]
    public string RuntimeStatusClass { get; set; } = string.Empty;

    [Parameter]
    public string BindingStatusText { get; set; } = string.Empty;

    [Parameter]
    public string BindingStatusClass { get; set; } = string.Empty;

    [Parameter]
    public string Eyebrow { get; set; } = string.Empty;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Description { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public IReadOnlyList<WorkspaceNavItem> NavigationItems { get; set; } = [];

    public sealed record WorkspaceNavItem(string Href, string Icon, string Title, string Description, NavLinkMatch Match = NavLinkMatch.Prefix);
}
